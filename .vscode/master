def get_child_list(df, parent_id):
    list_of_children = []
    list_of_children.append(df[df['ParentTerritory2Id'] == parent_id]['Id'].values)
    
    for i_, r_ in df[df['ParentTerritory2Id'] == parent_id].iterrows():
        if r_['Id'] != parent_id:
            list_of_children.append(get_child_list(df, r_['Id']))
    list_of_children = [item for sublist in list_of_children for item in sublist]
    return list_of_children

