def _describe(quires, instance_url, token , s3_resource, logger, pd, sf_config_metaendpoint, object_loc_meta_bucket,object_loc_meta_key):
    describe_error = []
    flag_firstrun = True
    p_data = pd.DataFrame()
    for objects in quires:
        make_url = str(instance_url) + str('{0}{1}/describe/'.format(str(sf_config_metaendpoint),str(objects)))
        try:
            R = requests.get(str(make_url),headers={'Authorization': 'Bearer ' + token, 'Content-type': 'application/json'})
            response_data = R.json()
            name = response_data['name']
            print("============================{0}".format(name))
            keyprefix = response_data['keyPrefix']
        except TypeError:
            describe_error.append(str(objects))
            continue
        if (describe_error):
            logger.info("_describe : META VISIBILITY FOR THE FOLLOWING - {0}".format(describe_error))
        fields_data = json.dumps(response_data['fields'])
        fields = json.loads(fields_data)
        pfields = json_normalize(fields)
        pfields = pfields[['name','type','encrypted','custom','byteLength','length','precision','scale']]
        pfields.insert(0, 'keyprefix', keyprefix)
        pfields.insert(0, 'object', name)
        pfields.replace({r'\A\s+|\s+\Z': '', '\n' : ' '}, regex=True, inplace=True)
        if flag_firstrun:
            p_data = pfields
            flag_firstrun = False
        else:
            p_data = p_data.append(pfields)
    csv_buffer = io.StringIO()
    p_data.to_csv(csv_buffer, sep='\t', encoding='utf-8', quoting=csv.QUOTE_ALL, quotechar='"', header=True, index=False)
    '''
    In subsequent line, please add all the compound salesforce data types.
    '''
    p_df = p_data[~p_data['type'].isin(['address'])]   #Changed for ADDRESS TYPE
    #p_df['name'] = p_df['name'].str.lower()
    grouped_df = p_df.groupby('object')['name'].apply(list)
    grouped_df.index = grouped_df.index.str.lower()
    object_names = grouped_df.index
    s3_resource.Object('{0}'.format(str(object_loc_meta_bucket)), '{0}'.format(str(object_loc_meta_key))).put(Body=csv_buffer.getvalue())
    csv_buffer.close()
    logger.info("_describe : Succesfully Completed execution")
    return (object_names, grouped_df)
def _define(s3_client, run_env, logger, object_loc_admin_bucket, object_loc_admin_key, object_loc_objlist_bucket, object_loc_objlist_key, config_lexi_env):
    config = configparser.ConfigParser()
    try :
        with tempfile.TemporaryDirectory() as tmp_dir:
            logger.info('Downloading File : {0}/{1}/config.ini'.format(str(object_loc_admin_bucket),str(object_loc_admin_key)))
            s3_client.download_file('{0}'.format(str(object_loc_admin_bucket)), '{0}/config.ini'.format(str(object_loc_admin_key)), '/{0}/config.ini'.format(tmp_dir))
            config.read('/{0}/config.ini'.format(tmp_dir))
            payload = {"client_id" : str(config['{0}'.format(str(config_lexi_env))]['client_id']),
                "client_secret" : str(config['{0}'.format(str(config_lexi_env))]['client_secret']),
                "username" : str(config['{0}'.format(str(config_lexi_env))]['username']),
                "password" : str(config['{0}'.format(str(config_lexi_env))]['password'])+str(config['{0}'.format(str(config_lexi_env))]['stoken']),
                "grant_type" : "password",
                "redirect_uri" : "https://{0}.salesforce.com/services/oauth2/success".format("login" if run_env == 'prod' else "test")}
    except Exception as e:
        logger.error("_define : {0}".format(str(e)))
        #_Sendmail("ERROR", str(BREADCRUMB), RECIPIENT)
        exit(0)
    try:
        fs = s3fs.S3FileSystem(anon=False)
        logger.info("s3://{0}/{1}".format(str(object_loc_objlist_bucket), str(object_loc_objlist_key)))
        object_file = fs.open("s3://{0}/{1}".format(str(object_loc_objlist_bucket), str(object_loc_objlist_key)), "r")
    except FileNotFoundError:
        logger.error("_define : Object file is not present")
        #_Sendmail("ERROR", str(BREADCRUMB), RECIPIENT)
        exit(0)
    try:
        R = requests.post("https://{0}.salesforce.com/services/oauth2/token".format("login" if run_env == 'prod' else "test"), \
        headers={"Content-Type":"application/x-www-form-urlencoded"}, data=payload)
    except requests.exceptions.Timeout:
        logger.error("_define : SFDC AUTH TIMEOUT")
        #_Sendmail("ERROR", str(BREADCRUMB), RECIPIENT)
        exit(0)
    except requests.exceptions.TooManyRedirects:
        logger.error("_define : SFDC AUTH REDIRECT LOOP")
        #_Sendmail("ERROR", str(BREADCRUMB), RECIPIENT)
        exit(0)
    except requests.exceptions.RequestException as e:
        logger.error("_define : SFDC AUTH PAYLOAD ERROR - {0}".format(str(e)))
        #_Sendmail("ERROR", str(BREADCRUMB), RECIPIENT)
        exit(0)
    response_data = json.loads(R.text)
    sf_token = response_data['access_token']
    sf_instance_url = response_data['instance_url']
    quires_normal = object_file.read().split(',') 
    quires_upper = [x.upper() for x in quires_normal]
    quires_dup = list(dict.fromkeys(quires_upper))
    quires = list(set(quires_dup))
    return(str(sf_instance_url), sf_token, sf_instance_url, quires)
def _getCount(logger, object_list, quires, instance_url, token, sf_config_countendpoint, sf_config_sosqlendpoint):
    make_url = str(instance_url) + str('{0}{1}'.format(str(sf_config_countendpoint),str(object_list)))
    METAQL = str(instance_url) + str(sf_config_sosqlendpoint) + "COUNT()+FROM+"
    sorted_objects = {}
    try:
        R = requests.get(str(make_url),headers={'Authorization': 'Bearer ' + token, 'Content-type': 'application/json'})
        response_data = R.json()
        oj_dict = json.loads(json.dumps(response_data['sObjects']))
        for objects in quires:
            if objects not in [ ob['name'] for ob in oj_dict ]:
                R = requests.get("{0}{1}".format(str(METAQL),objects),headers={'Authorization': 'Bearer ' + token, 'Content-type': 'application/json'})
                response_data = R.json()
                try:
                    oj_dict.append({"count":response_data['totalSize'],"name":objects})
                except TypeError:
                    continue
        sorted_objects = sorted(oj_dict, key = lambda i: i['count'])
    except TypeError:
        logger.error("_getCount : RECORDCOUNT NOT IN JSON")
        return({})           
    logger.error("_getCount : Succesfully Completed execution")
    print(sorted_objects)
    return(sorted_objects)
