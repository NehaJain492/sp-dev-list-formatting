try:
    client = boto3.client('glue',region_name='eu-central-1')
    s3 = boto3.client('s3')
    crawler_name = 'victoria-prd-mpp-{0}-{1}'.format(str(run_env),str(run_region)) if run_project == 'ioengage' else 'data-ioccs-{0}-export-csv'.format(str(run_env))
    meta_key = '{0}/meta/{1}/{2}/meta.csv'.format(str(run_project),str(run_region),str(run_env))
    database_name = 'oce-{1}-{0}'.format(str(run_env),str(run_region)) if run_project == 'ioengage' else 'ioccs-{0}-export-{1}'.format(str(run_region),str(run_env))
    if run_project in ['ioengage','ioccs']:
        response = client.get_crawler(Name=crawler_name)
        obj = s3.get_object(Bucket='victoria-prd-eu-lambda', Key=meta_key)
        body = obj['Body']
        csv_string = body.read().decode('utf-8')
        df = pd.read_csv(StringIO(csv_string),delimiter="\t")
        df['col_dict'] = df.apply(lambda row: {row['name']:row['type']}, axis=1)
        df["object"] = df["object"].str.lower()
        df_grouped = df.groupby('object')['col_dict'].apply(list)
        update_column = []
        for tables in response['Crawler']['Targets']['S3Targets']:
            entity = tables['Path'].split('/')[-2]
            with tempfile.TemporaryDirectory() as tmpdirname:
                os.system("aws s3api get-object --bucket victoria-prd-eu-lambda --range bytes=0-30000 --key {0}{1}.csv {2}/temp".format(str(tables['Path']).replace('s3://victoria-prd-eu-lambda/',''),str(entity),str(tmpdirname)))
                try:
                    file = open("{0}/temp".format(str(tmpdirname)),encoding="utf8")
                except FileNotFoundError:
                    print("Object data not present")
                    continue
                line = file.readline()
                file.close()
                line = line.rstrip()
                line = line.replace('"','')
                columns = re.split(r'\t+',line)
                columns[0] = 'row_number'
                columns_lower = [x.lower().replace('.','_').replace('tolabel(','').replace(')','') for x in columns]
                try:
                    meta_col = df_grouped.loc['{0}'.format(str(entity).lower())]
                except KeyError:
                    continue
                update_column=[]
                update_column.append({'Name': 'row_number', 'Type': 'bigint'})
                for outer_col in columns_lower:
                    meta_flag = False
                    for col in meta_col:
                        for key, val in col.items():
                            if str(key).lower()==outer_col:
                                meta_flag = True
                                if val in ['boolean']:
                                    update_column.append({'Name': outer_col, 'Type': str(val)})
                                else:
                                    update_column.append({'Name': outer_col, 'Type': 'string'})
                    if not meta_flag and outer_col not in ['row_number']:
                        update_column.append({'Name': outer_col, 'Type': 'string'})
                tabl_resp = client.get_table(DatabaseName=database_name,Name='csv_{0}'.format(str(entity).lower()))
                tabl_resp['Table']['StorageDescriptor']['Columns']=update_column
                update_t = tabl_resp['Table']
                update_t.pop('DatabaseName', None)
                update_t.pop('CreateTime', None)
                update_t.pop('UpdateTime', None)
                update_t.pop('CreatedBy', None)
                update_t.pop('IsRegisteredWithLakeFormation', None)
                update_t.pop('CatalogId', None)
                response = client.update_table(DatabaseName=database_name.format(str(run_env),str(run_region)),TableInput=update_t)
except Exception as e:
    print("Crawler field update error - {}".format(str(e)))
