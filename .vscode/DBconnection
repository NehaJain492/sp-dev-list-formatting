import sys
import boto3
from awsglue.transforms import *
from awsglue.utils import getResolvedOptions
import pg8000
import json

## @params: [JOB_NAME]
args = getResolvedOptions(sys.argv, ['JOB_NAME', 'DB', 'HOST', 'PW', 'USER'])

#PG8000config
conn = pg8000.connect(
    database=args['DB'], 
    user=args['USER'], 
    password=args['PW'],
    host=args['HOST'],
    port=5432
)

s3_client = boto3.client('s3')
response = s3_client.get_object(Bucket="victoria-prd-s3-eu-reference",Key="ioengage/aameo/sql/AAMEO_IO_ENGAGE_DB_VIEWS_LIST.txt")
content = response["Body"]
query_list = json.load(content)
cur = conn.cursor()

for query in query_list:
    try:
        cur.execute(query)
        conn.commit()
    except Exception as e:
        print(e)
        continue
cur.close()
conn.close()
