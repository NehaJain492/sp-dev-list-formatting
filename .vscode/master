def csv_dataframe(prefix, encoding, columns):
    s3resource = boto3.resource('s3')
    bucket = s3resource.Bucket(SRCBUCKET)
    prefix_objs = bucket.objects.filter(Prefix=prefix)
    prefix_df = []
    filter_cols = ['Id', 'LastModifiedDate']
    for obj in prefix_objs:
        if '.csv' in obj.key:
            body = obj.get()['Body'].read().decode(encoding)
            df = (pd.read_csv(io.StringIO(body), quotechar='"', sep='\t', dtype='str', \
            on_bad_lines='skip', usecols=columns+filter_cols))
            prefix_df.append(df)
    DF = pd.concat(prefix_df).sort_values(by='LastModifiedDate')
    DF = DF.drop_duplicates(['Id'], keep='last')[columns]
    return DF

